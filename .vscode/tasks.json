{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build YMC-toolkit",
            "type": "shell",
            "command": "g++",
            "args": [
                "-Wall", "-Wextra", "-g3",
                "-I", "d:/table/YMC-toolkit/include",
                "d:/table/YMC-toolkit/src/*.cpp",      // 编译所有源文件
                "-o", "d:/table/YMC-toolkit/bin/YMC-toolkit.exe",
                "-lws2_32", "-lgdiplus", "-lshell32"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}